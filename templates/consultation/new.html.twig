{% extends 'base.html.twig' %}

{% block title %}Nouvelle Consultation{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/medecin/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/consultation/form.css') }}">
    <style>
        body { 
            background: linear-gradient(135deg, #ecf7fa 0%, #f5f9fc 100%); 
            min-height: 100vh; 
        }
        .portal__card { 
            background: white; 
            border-radius: 12px; 
            box-shadow: 0 2px 8px rgba(10, 123, 167, 0.08);
            border: 1px solid #e0f2f7;
        }
        .portal__title { 
            font-size: 28px; 
            font-weight: 700; 
            color: #0a7ba7;
            letter-spacing: -0.5px; 
            margin: 0; 
        }
        .portal__subtitle { 
            font-size: 14px; 
            color: #4a6fa5; 
            line-height: 1.6; 
            margin-top: 8px; 
        }
        .form__field { 
            margin-bottom: 20px; 
            display: flex; 
            flex-direction: column;
            width: 100%;
        }
        .form__field:last-child {
            margin-bottom: 0;
        }
        .form__field label { 
            font-weight: 600; 
            font-size: 13px;
            margin-bottom: 8px;
            color: #0a7ba7;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input[type="text"],
        input[type="email"],
        input[type="date"],
        select,
        textarea {
            padding: 11px 13px;
            border: 1px solid #c7e8f0;
            border-radius: 6px;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.2s;
            background: #fafcfd;
            color: #2c3e50;
        }
        input::placeholder,
        textarea::placeholder {
            color: #a0b8c5;
        }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #0a7ba7;
            background: white;
            box-shadow: 0 0 0 3px rgba(10, 123, 167, 0.08);
        }
        .grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .grid-three { display: grid; grid-template-columns: 1fr 120px 80px; gap: 16px; }
        .full-width { grid-column: 1 / -1; }
        textarea { 
            min-height: 140px; 
            resize: vertical;
            font-family: inherit;
            line-height: 1.5;
        }
        .motif-enhancement {
            margin-top: 12px; 
            padding: 14px; 
            background: #f0fafb;
            border-radius: 6px;
            border: 1px solid #b3dce8;
            font-size: 13px; 
            transition: all 0.3s ease;
        }
        .motif-enhancement.success { 
            background: #f0faf7;
            border-color: #70c9a8;
            color: #00897b;
        }
        .motif-enhancement.error { 
            background: #faf5f5;
            border-color: #f0a8a2;
            color: #c62828;
        }
        .enhance-btn {
            background: #00897b;
            color: white; 
            border: none; 
            padding: 10px 18px; 
            border-radius: 6px;
            cursor: pointer; 
            font-size: 13px; 
            font-weight: 600;
            display: inline-flex; 
            align-items: center; 
            gap: 6px; 
            transition: all 0.2s ease;
        }
        .enhance-btn:hover { 
            background: #00695c;
        }
        .enhance-btn:disabled { 
            opacity: 0.6; 
            cursor: not-allowed; 
        }
        .form__actions {
            display: flex; 
            gap: 12px; 
            margin-top: 28px; 
            padding-top: 20px;
            border-top: 1px solid #e0f2f7;
        }
        .btn { 
            border-radius: 6px; 
            font-weight: 600; 
            padding: 11px 24px; 
            font-size: 14px; 
            transition: all 0.2s;
            border: none;
        }
        .btn--primary { 
            background: #0a7ba7;
            color: white;
        }
        .btn--primary:hover { 
            background: #055a7e;
        }
        .btn--ghost { 
            background: transparent; 
            color: #0a7ba7; 
            border: 1px solid #c7e8f0;
        }
        .btn--ghost:hover { 
            background: #f0fafb; 
        }
        .form__section {
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 1px solid #e0f2f7;
        }
        .form__section:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .form__section-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        .form__section-title {
            font-size: 16px;
            font-weight: 700;
            color: #0a7ba7;
            margin: 0;
        }
        .form__section-emoji {
            font-size: 20px;
        }
        .form__advice {
            background: linear-gradient(135deg, #f0fafb 0%, #e8f4f8 100%);
            border: 2px solid #0a7ba7;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 24px;
        }
        .form__advice-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            color: #0a7ba7;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }
        .form__advice-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .form__advice-list li {
            padding: 8px 0;
            padding-left: 24px;
            color: #4a6fa5;
            font-size: 13px;
            line-height: 1.5;
            position: relative;
        }
        .form__advice-list li:before {
            content: "✓";
            position: absolute;
            left: 0;
            color: #00897b;
            font-weight: bold;
        }
        .form__fields {
            display: flex !important;
            flex-direction: column !important;
            gap: 0 !important;
        }
    </style>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/consultation-slots.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const motifInput = document.querySelector('textarea[name*="motif"]') || document.querySelector('input[name*="motif"]');
            const enhanceBtn = document.getElementById('enhance-motif-btn');
            const enhancementPanel = document.getElementById('motif-enhancement');
            
            if (enhanceBtn && motifInput) {
                enhanceBtn.addEventListener('click', async function(e) {
                    e.preventDefault();
                    const motif = motifInput.value.trim();
                    
                    if (!motif) {
                        showEnhancementMessage(enhancementPanel, 'error', '❌ Veuillez remplir le motif');
                        return;
                    }
                    
                    enhanceBtn.disabled = true;
                    enhanceBtn.innerHTML = '⏳ Analyse en cours...';
                    
                    try {
                        const response = await fetch('/consultation/analyze-motif?motif=' + encodeURIComponent(motif));
                        const data = await response.json();
                        
                        if (data.ok) {
                            const urgencyMap = { 'faible': 'low', 'moderee': 'medium', 'elevee': 'high' };
                            const urgencyLevel = urgencyMap[data.urgency] || 'medium';
                            
                            const urgencyConfig = {
                                'low': { emoji: '🟢', label: 'Faible', color: '#00897b' },
                                'medium': { emoji: '🟡', label: 'Modérée', color: '#ffa726' },
                                'high': { emoji: '🔴', label: 'ÉLEVÉE', color: '#ef5350' }
                            };
                            
                            const config = urgencyConfig[urgencyLevel];
                            motifInput.value = data.enhanced || data.original;
                            
                            const messageHTML = '<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;"><span style="font-size: 20px;">' + config.emoji + '</span><div><strong style="font-size: 14px; color: ' + config.color + ';">Urgence: ' + config.label + '</strong></div></div>';
                            
                            showEnhancementMessage(enhancementPanel, 'success', messageHTML);
                        } else {
                            showEnhancementMessage(enhancementPanel, 'error', '❌ ' + (data.message || data.error || 'Erreur lors de l\'analyse'));
                        }
                    } catch (error) {
                        console.error('AI Analysis error:', error);
                        showEnhancementMessage(enhancementPanel, 'error', '❌ Erreur de connexion');
                    } finally {
                        enhanceBtn.disabled = false;
                        enhanceBtn.innerHTML = '✨ Analyser avec IA';
                    }
                });
            }
            
            function showEnhancementMessage(panel, type, message) {
                if (!panel) return;
                panel.className = 'motif-enhancement ' + type;
                panel.innerHTML = message;
                panel.style.display = 'block';
            }
        });
    </script>
{% endblock %}

{% block body %}
<div class="portal">
    {% include 'side_bar.html.twig' %}

    <main class="portal__main">
        <header class="portal__header">
            <h1 class="portal__title">Nouvelle consultation</h1>
            <p class="portal__subtitle">Remplissez le formulaire ci-dessous pour prendre rendez-vous</p>
        </header>

        <section class="portal__content portal__card">
            {{ form_start(form, {'attr': {'class': 'form', 'novalidate': 'novalidate'}}) }}

                <div class="form__fields">
                    <div class="form__section">
                        <div class="form__section-header">
                            <span class="form__section-emoji">📅</span>
                            <h2 class="form__section-title">Choisissez votre rendez-vous</h2>
                        </div>
                        
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 16px;">
                            <div style="width: 100%;">{{ form_row(form.dateConsultation) }}</div>
                            <div style="width: 100%;">{{ form_row(form.timeSlot) }}</div>
                        </div>
                        
                        {% include 'consultation/slots-helper.html.twig' %}
                    </div>

                    <div class="form__section">
                        <div class="form__section-header">
                            <span class="form__section-emoji">🩺</span>
                            <h2 class="form__section-title">Décrivez vos symptômes</h2>
                        </div>
                        
                        <div style="padding: 16px;">
                            <div class="form__advice">
                                <div class="form__advice-title">💡 Comment bien描述 ?</div>
                                <ul class="form__advice-list">
                                    <li><strong>Principal symptôme:</strong> Mal de gorge, douleur thoracique, fièvre...</li>
                                    <li><strong>Depuis combien de temps ?</strong> 2 jours, 1 semaine...</li>
                                    <li><strong>Intensité:</strong> Léger, modéré, intense ?</li>
                                    <li><strong>Contexte:</strong> Maladies chroniques ou antécédents ?</li>
                                </ul>
                            </div>
                            
                            {{ form_row(form.motif) }}
                            <div style="display: flex; gap: 8px; margin-top: 12px; margin-bottom: 20px;">
                                <button type="button" id="enhance-motif-btn" class="enhance-btn" title="Analyser et améliorer votre description avec l'IA">
                                    ✨ Analyser avec IA
                                </button>
                            </div>
                            <div id="motif-enhancement" class="motif-enhancement" style="display: none;"></div>
                        </div>
                    </div>

                    <div class="form__section">
                        <div class="form__section-header">
                            <span class="form__section-emoji">👤</span>
                            <h2 class="form__section-title">Vos informations</h2>
                        </div>
                        
                        <div style="padding: 16px;">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                                <div style="width: 100%;">{{ form_row(form.name) }}</div>
                                <div style="width: 100%;">{{ form_row(form.familyName) }}</div>
                            </div>
                            
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                                <div style="width: 100%;">{{ form_row(form.email) }}</div>
                                <div style="width: 100%;">{{ form_row(form.sex) }}</div>
                            </div>
                            
                            <div style="display: grid; grid-template-columns: 1fr; gap: 20px;">
                                <div style="width: 100%;">{{ form_row(form.age) }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form__actions">
                    <a href="{{ path('patient_consultations') }}" class="btn btn--ghost">Annuler</a>
                    <button type="submit" class="btn btn--primary">Créer consultation</button>
                </div>

            {{ form_end(form) }}
        </section>

    </main>

</div>
{% endblock %}
