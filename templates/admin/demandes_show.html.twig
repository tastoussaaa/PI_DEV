{% extends 'base.html.twig' %}

{% block title %}{{ demande.titreD }} - Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/medecin/dashboard.css') }}">
    <style>
        .detail-shell { display: grid; grid-template-columns: 2fr 1fr; gap: 40px; max-width: 1400px; }
        .detail-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04); }
        .detail-card__head { padding: 20px 24px; background: #f8fafc; border-bottom: 1px solid #e5e7eb; font-weight: 700; font-size: 16px; }
        .detail-card__body { padding: 28px; }
        .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .meta-item { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px; padding: 16px; }
        .meta-item strong { display:block; color:#475569; font-size:12px; margin-bottom:8px; letter-spacing: 0.5px; }
        .desc-box { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px; padding: 18px; color: #334155; line-height: 1.6; }

        .status-chip { padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; }
        .status-success { background: #bbf7d0; color: #14532d; }
        .status-warning { background: #fde68a; color: #78350f; }
        .status-danger { background: #fecaca; color: #7f1d1d; }
        .status-expired { background: #ddd6fe; color: #4c1d95; }
        .status-dark { background: #e2e8f0; color: #1e293b; }

        .action-stack { display: grid; gap: 16px; }
        .action-btn { width: 100%; border: 1px solid transparent; border-radius: 8px; padding: 14px 18px; font-weight: 600; display: block; text-align: center; font-size: 14px; }
        .action-btn--edit { background: #fde68a; border-color: #fcd34d; color: #78350f; }
        .action-btn--delete { background: #fecaca; border-color: #fca5a5; color: #7f1d1d; }
        .action-btn--link { background: #bfdbfe; border-color: #93c5fd; color: #1e3a8a; text-decoration: none; border-radius: 8px; }

        .mini-table { width: 100%; border-collapse: collapse; }
        .mini-table th { text-align:left; font-size:13px; color:#64748b; padding:16px; border-bottom:2px solid #e5e7eb; }
        .mini-table td { padding:16px; border-bottom:1px solid #f1f5f9; font-size: 14px; }

        .detail-page { padding: 12px 0 32px; }
        .section-gap { margin-bottom: 32px; }

        @media (max-width: 992px) {
            .detail-shell { grid-template-columns: 1fr; }
            .meta-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="portal">
    {% include 'side_bar.html.twig' %}

    <main class="portal__main">
        <div class="portal__top">
            <div>
                <h1 class="portal__title">📋 {{ demande.titreD }}</h1>
                <p class="portal__subtitle">Détail de la demande #{{ demande.id }}</p>
            </div>
        </div>

        <div class="portal__content">
<div class="container detail-page">
    <div class="section-gap">
        <div>
            <a href="{{ path('admin_demandes') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>

    {# Messages Flash #}
    {% if app.flashes %}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type === 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    <div class="detail-shell">
        <div>
            {# Informations Demande #}
            <div class="detail-card section-gap">
                <div class="detail-card__head">📋 Informations de la Demande</div>
                <div class="detail-card__body">
                    {% set demandeStatusClass = demande.statut == 'ACCEPTÉE' ? 'status-success' : (demande.statut == 'EN_ATTENTE' ? 'status-warning' : (demande.statut == 'EXPIRÉE' ? 'status-expired' : 'status-danger')) %}
                    <div class="meta-grid" style="margin-bottom: 24px;">
                        <div class="meta-item"><strong>Email patient</strong>{{ demande.email }}</div>
                        <div class="meta-item"><strong>Statut</strong><span class="status-chip {{ demandeStatusClass }}">{{ demande.statut|replace({'_':' '}) }}</span></div>
                        <div class="meta-item"><strong>Date création</strong>{{ demande.dateCreation ? demande.dateCreation|date('d/m/Y H:i') : '-' }}</div>
                        <div class="meta-item"><strong>Date début souhaitée</strong>{{ demande.dateDebutSouhaitee ? demande.dateDebutSouhaitee|date('d/m/Y') : '-' }}</div>
                        <div class="meta-item"><strong>Date fin souhaitée</strong>{{ demande.dateFinSouhaitee ? demande.dateFinSouhaitee|date('d/m/Y') : '-' }}</div>
                        <div class="meta-item"><strong>Budget max</strong>{{ demande.budgetMax ? demande.budgetMax ~ ' DT' : '-' }}</div>
                        <div class="meta-item"><strong>Type patient</strong>{{ demande.typePatient }}</div>
                        <div class="meta-item"><strong>Sexe</strong>{{ demande.sexe ? (demande.sexe == 'M' ? 'Homme' : 'Femme') : '-' }}</div>
                    </div>

                    <div style="margin-bottom: 24px;">
                        <strong style="display: block; margin-bottom: 12px; font-size: 13px; color: #475569; letter-spacing: 0.5px;">Lieu</strong>
                        <div class="desc-box">{{ demande.lieu ?? demande.ville ?? '-' }}</div>
                    </div>

                    <div>
                        <strong style="display: block; margin-bottom: 12px; font-size: 13px; color: #475569; letter-spacing: 0.5px;">Description</strong>
                        <div class="desc-box">{{ demande.descriptionBesoin }}</div>
                    </div>
                </div>
            </div>

            {# Missions Liées #}
            {% if demande.missions|length > 0 %}
                <div class="detail-card">
                    <div class="detail-card__head">🎯 Missions Liées</div>
                    <div class="detail-card__body" style="padding: 0;">
                        <div style="overflow-x:auto;">
                        <table class="mini-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Aide-Soignant</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for mission in demande.missions %}
                                    <tr>
                                        <td>#{{ mission.id }}</td>
                                        <td>{{ mission.aideSoignant ? (mission.aideSoignant.nom ~ ' ' ~ mission.aideSoignant.prenom) : 'Non attribuée' }}</td>
                                        <td>
                                            {% set missionStatusClass = mission.statutMission == 'ACCEPTÉE' ? 'status-success' : (mission.statutMission == 'TERMINÉE' ? 'status-dark' : (mission.statutMission == 'EXPIRÉE' ? 'status-expired' : (mission.statutMission == 'ANNULÉE' ? 'status-danger' : 'status-warning'))) %}
                                            <span class="status-chip {{ missionStatusClass }}">{{ mission.statutMission|replace({'_':' '}) }}</span>
                                        </td>
                                        <td>
                                            <a href="{{ path('admin_missions_show', {id: mission.id}) }}" class="action-btn--link">Voir</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        <div>
            {# Actions #}
            <div class="detail-card">
                <div class="detail-card__head">⚙️ Actions</div>
                <div class="detail-card__body action-stack">
                    <a href="{{ path('admin_demandes_edit', {id: demande.id}) }}" class="action-btn action-btn--edit">Modifier</a>
                    
                    <form method="post" action="{{ path('admin_demandes_delete', {id: demande.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette demande ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-demande-' ~ demande.id) }}">
                        <button type="submit" class="action-btn action-btn--delete">Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

        </div>
    </main>
</div>
{% endblock %}
