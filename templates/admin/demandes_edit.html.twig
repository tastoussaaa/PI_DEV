{% extends 'base.html.twig' %}

{% block title %}Modifier Demande - Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/medecin/dashboard.css') }}">
{% endblock %}

{% block body %}
<div class="portal">
    {% include 'side_bar.html.twig' %}

    <main class="portal__main">
        <div class="portal__content">
<div class="container py-4">
    <div class="row mb-4">
        <div class="col-auto">
            <a href="{{ path('admin_demandes_show', {id: demande.id}) }}" class="btn btn-secondary">← Retour</a>
        </div>
        <div class="col">
            <h1>✏️ Modifier Demande</h1>
            <p class="text-muted">{{ demande.titreD }}</p>
        </div>
    </div>

    {# Messages Flash #}
    {% if app.flashes %}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type === 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form method="post" action="{{ path('admin_demandes_edit', {id: demande.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('edit-demande-' ~ demande.id) }}">

                        <div class="mb-3">
                            <label for="statut" class="form-label">Statut</label>
                            <select name="statut" id="statut" class="form-select">
                                <option value="EN_ATTENTE" {{ demande.statut === 'EN_ATTENTE' ? 'selected' : '' }}>En attente</option>
                                <option value="ACCEPTÉE" {{ demande.statut === 'ACCEPTÉE' ? 'selected' : '' }}>Acceptée</option>
                                <option value="A_REASSIGNER" {{ demande.statut === 'A_REASSIGNER' ? 'selected' : '' }}>À réassigner</option>
                                <option value="EXPIRÉE" {{ demande.statut === 'EXPIRÉE' ? 'selected' : '' }}>Expirée</option>
                                <option value="ANNULÉE" {{ demande.statut === 'ANNULÉE' ? 'selected' : '' }}>Annulée</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="dateFinSouhaitee" class="form-label">Date Fin Souhaitée</label>
                            <input type="date" name="dateFinSouhaitee" id="dateFinSouhaitee" class="form-control" 
                                   value="{{ demande.dateFinSouhaitee ? demande.dateFinSouhaitee|date('Y-m-d') : '' }}">
                        </div>

                        <div class="alert alert-info">
                            <strong>ℹ️ Info:</strong> Vous pouvez modifier le statut et la date de fin souhaitée. Les autres informations sont en lecture seule.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">💾 Enregistrer</button>
                            <a href="{{ path('admin_demandes_show', {id: demande.id}) }}" class="btn btn-secondary">Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header">
                    <h5 class="mb-0">📋 Infos Actuelles</h5>
                </div>
                <div class="card-body">
                    <p><strong>Email:</strong> {{ demande.email }}</p>
                    <p><strong>Titre:</strong> {{ demande.titreD }}</p>
                    <p><strong>Date Création:</strong> {{ demande.dateCreation|date('d/m/Y') }}</p>
                    <p><strong>Date Début:</strong> {{ demande.dateDebutSouhaitee|date('d/m/Y') }}</p>
                    <p><strong>Budget:</strong> {{ demande.budgetMax }} DT</p>
                </div>
            </div>
        </div>
    </div>
</div>

        </div>
    </main>
</div>
{% endblock %}
