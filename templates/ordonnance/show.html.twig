{% extends 'base.html.twig' %}

{% block title %}Ordonnances{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/medecin/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/consultation/form.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/ordonnance.css') }}">
{% endblock %}

{% block body %}
<div class="portal">

    {% include 'side_bar.html.twig' %}

    <main class="portal__main">

        <header class="portal__header" style="margin-bottom: 24px;">
            <h1 class="portal__title" style="font-size: 28px; font-weight: 980; letter-spacing: -.6px;">Toutes les ordonnances</h1>
            <p class="portal__subtitle" style="color: rgba(7,19,31,.60); margin-top: 6px;">Liste des ordonnances avec actions.</p>
        </header>

        <section class="portal__content">

            <div class="search-bar">
                <form method="get">
                    <input type="text" name="search" placeholder="Rechercher par medicament, consultation ou date..." value="{{ search }}">
                    <select name="sort">
                        <option value="date" {% if sort == 'date' %}selected{% endif %}>Le plus récent en premier</option>
                        <option value="medicament" {% if sort == 'medicament' %}selected{% endif %}>Médicaments de A à Z</option>
                        <option value="consultation" {% if sort == 'consultation' %}selected{% endif %}>Nom de la Consultation</option>
                    </select>
                    <button type="submit" class="btn btn--primary">Rechercher</button>
                    {% if search or sort != 'date' %}
                        <a href="{{ path('Ordonnance_show_all') }}" class="btn btn--ghost">Réinitialiser</a>
                    {% endif %}
                </form>
            </div>

            <div class="ordo-table-container">
                {% if ordonnances is empty %}
                    <div class="ordo-empty">
                        <div class="ordo-empty-icon">📋</div>
                        <p style="font-size: 16px; font-weight: 900;">Aucune ordonnance disponible</p>
                        <p style="font-size: 14px; margin-top: 8px;">Créez une nouvelle ordonnance pour commencer.</p>
                    </div>
                {% else %}
                    <table class="ordo-table">
                        <thead>
                            <tr>
                                <th style="width: 25%;">Médicament</th>
                                <th style="width: 15%;">Dosage</th>
                                <th style="width: 12%;">Durée</th>
                                <th style="width: 20%;">Consultation</th>
                                <th style="width: 10%;">Créé</th>
                                <th style="width: 18%;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for o in ordonnances %}
                                <tr>
                                    <td>
                                        {% if o.medicaments|length > 0 %}
                                            <div class="medicament-list">
                                                {% for med in o.medicaments %}
                                                    <span class="medicament-pill">{{ med.medicament }}</span>
                                                {% endfor %}
                                            </div>
                                        {% else %}
                                            <span style="color: rgba(7,19,31,.40);">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if o.medicaments|length > 0 %}
                                            <div class="medicament-list">
                                                {% for med in o.medicaments %}
                                                    <span class="medicament-pill medicament-pill--dosage">{{ med.dosage ?: '—' }}</span>
                                                {% endfor %}
                                            </div>
                                        {% else %}
                                            {{ o.dosage ?: '—' }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if o.medicaments|length > 0 %}
                                            <div class="medicament-list">
                                                {% for med in o.medicaments %}
                                                    <span class="medicament-pill medicament-pill--duree">{{ med.duree ?: '—' }}</span>
                                                {% endfor %}
                                            </div>
                                        {% else %}
                                            {{ o.duree ?: '—' }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if o.consultation %}
                                            <div class="ordo-patient">
                                                <span class="ordo-patient-name">{{ o.consultation.name }} {{ o.consultation.familyName }}</span>
                                            </div>
                                        {% else %}
                                            <span style="color: rgba(7,19,31,.40);">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if o.createdAt %}
                                            <span class="ordo-badge ordo-badge--date">{{ o.createdAt|date('d/m/Y') }}</span>
                                        {% else %}
                                            <span style="color: rgba(7,19,31,.40);">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="ordo-actions">
                                            {% if o.consultation %}
                                                <a href="{{ path('download_consultation_pdf', {'consultationId': o.consultation.id}) }}" class="btn btn--ghost" title="Télécharger PDF" style="padding: 8px 10px; font-size: 14px;">
                                                    📥
                                                </a>
                                            {% endif %}
                                            <a href="{{ path('Ordonnance_show', {'id': o.id}) }}" class="btn btn--ghost" style="padding: 8px 14px; font-size: 13px;">
                                                Détails
                                            </a>
                                            <a href="{{ path('Ordonnance_edit', {'id': o.id}) }}" class="btn btn--primary" style="padding: 8px 14px; font-size: 13px;">
                                                Modifier
                                            </a>
                                            <form method="post" action="{{ path('Ordonnance_delete', {'id': o.id}) }}" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ o.id) }}">
                                                <button type="submit" class="btn btn-delete" onclick="return confirm('Supprimer cette ordonnance?')">
                                                    Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>

        </section>

    </main>

</div>
{% endblock %}
