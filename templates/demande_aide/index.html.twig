{% extends 'base.html.twig' %}

{% block title %}Mes demandes d'aide{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/medecin/dashboard.css') }}">
    <style>
        .cards__grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 32px;
            padding: 0;
        }
        
        @media (max-width: 1200px) {
            .cards__grid {
                grid-template-columns: 1fr;
                gap: 24px;
            }
        }
        
        .card {
            position: relative;
            padding: 24px;
            background: white;
            border-radius: 12px;
            border: 1px solid #eee;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }
        
        .card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
            transform: translateY(-2px);
        }
        
        .card h3 {
            margin: 0 0 12px 0;
            font-size: 18px;
            color: #333;
            font-weight: 600;
        }
        
        .card p {
            margin: 12px 0;
            color: #666;
            line-height: 1;
            flex-grow: 1;
        }
        
         .card__actions {
            display: flex;
            gap: 12px;
            margin-top: auto;
            padding-top: 16px;
        }

        .card__actions a,
        .card__actions button,
        .card__actions form {
            flex: 1;
            min-width: 0;
        }

        .card__actions form {
            display: flex;
            margin: 0;
        }

        .card__actions form button {
            flex: 1;
        }

        .card__actions a,
        .card__actions button {
            padding: 12px 16px;
            font-size: 14px;
            border-radius: 6px;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        
        .btn--info {
            background: #B3E5FC;
            color: #01579B;
            border: none;
        }

        .btn--info:hover {
            background: #81D4FA;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(3, 155, 229, 0.2);
        }

        .btn--edit {
            background: #FFD8B8;
            color: #D27600;
            border: none;
        }

        .btn--edit:hover {
            background: #FFCCA3;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(210, 118, 0, 0.2);
        }

        .btn--select {
            background: #C8E6C9;
            color: #2E7D32;
            border: none;
        }

        .btn--select:hover {
            background: #A5D6A7;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.2);
        }

        .btn--danger {
            background: #FFCCCC;
            color: #C62828;
            border: none;
        }

        .btn--danger:hover {
            background: #FFADAD;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(198, 40, 40, 0.2);
        }
        
        .card__status {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-top: 12px;
        }
        
        .status--urgent {
            background: #FFE0B2;
            color: #E65100;
            border: 1px solid rgba(230, 81, 0, 0.15);
        }
        
        .status--normal {
            background: #C8E6C9;
            color: #1B5E20;
            border: 1px solid rgba(27, 94, 32, 0.15);
        }
        
        .status--economie {
            background: #E1BEE7;
            color: #6A1B9A;
            border: 1px solid rgba(106, 27, 154, 0.15);
        }
        
        .status--en_attente {
            background: #FFF9C4;
            color: #F57F17;
            border: 1px solid rgba(245, 127, 23, 0.15);
        }
        
        .status--accepted {
            background: #C8E6C9;
            color: #2E7D32;
            border: 1px solid rgba(46, 125, 50, 0.15);
        }

        .status--refused {
            background: #FFCCCC;
            color: #D32F2F;
            border: 1px solid rgba(211, 47, 47, 0.15);
        }

        .status--completed {
            background: #C8E6C9;
            color: #2E7D32;
            border: 1px solid rgba(46, 125, 50, 0.15);
        }

        .status--expired {
            background: #FFE0B2;
            color: #E65100;
            border: 1px solid rgba(230, 81, 0, 0.15);
        }

        .status--cancelled {
            background: #FFCDD2;
            color: #C62828;
            border: 1px solid rgba(198, 40, 40, 0.15);
        }

        .urgency-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .card__info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid #eee;
            font-size: 13px;
            color: #666;
        }
        
        .card__info strong {
            color: #333;
        }
    </style>
{% endblock %}

{% block body %}

{% set navigation = [
    { path: '/demandes', name: 'Mes demandes', icon: '📋' },
    { path: '/demande/aide', name: 'Créer une demande d\'aide', icon: '➕' }
] %}

<div class="portal">
    {% include 'side_bar.html.twig' %}

    <main class="portal__main">
        <div class="portal__top">
            <div>
                <h1 class="portal__title">Mes demandes d'aide</h1>
                <p class="portal__subtitle">Consultez et gérez toutes vos demandes d'aide</p>
            </div>
            <div style="display: flex; gap: 12px;">
                <a href="{{ path('app_demande_aide') }}" class="btn btn--primary">+ Créer une demande</a>
                <a href="{{ path('app_demandes_history') }}" class="btn btn--info" style="background: #17a2b8; color: white; text-decoration: none; padding: 10px 16px; border-radius: 6px; font-weight: 600; display: flex; align-items: center; gap: 6px;">📚 Historique</a>
            </div>
        </div>

        {% if demandesAide is empty %}
            <div class="box">
                <p style="text-align: center; color: var(--muted);">Vous n'avez aucune demande d'aide pour le moment.</p>
                <p style="text-align: center; margin-top: 16px;">
                    <a href="{{ path('app_demande_aide') }}" class="btn btn--primary">Créer votre première demande</a>
                </p>
            </div>
        {% else %}
            <div class="cards">
                <div class="cards__grid">
                    {% for demande in demandesAide %}
                        <div class="card">
                            <div style="display: flex; justify-content: space-between; align-items: start; gap: 12px;">
                                <div>
                                    <h3 style="margin: 0 0 12px 0;">{{ demande.titreD }}</h3>
                                    <span class="card__status status--{{ demande.typeDemande|lower }}">{{ demande.typeDemande }}</span>
                                    {% if demande.urgencyScore is not null %}
                                        {% set urgencyLevel = demande.urgencyScore >= 80 ? 'CRITICAL' : (demande.urgencyScore >= 60 ? 'HIGH' : (demande.urgencyScore >= 40 ? 'MEDIUM' : 'LOW')) %}
                                        {% set urgencyColor = demande.urgencyScore >= 80 ? '#DC3545' : (demande.urgencyScore >= 60 ? '#FD7E14' : (demande.urgencyScore >= 40 ? '#FFC107' : '#28A745')) %}
                                        <span class="urgency-badge" style="background: {{ urgencyColor }}15; color: {{ urgencyColor }}; border: 1px solid {{ urgencyColor }}30; margin-left: 8px;">
                                            🔥 {{ urgencyLevel }} ({{ demande.urgencyScore }})
                                        </span>
                                    {% endif %}
                                </div>
                                {% set statusClass = {
                                    'ACCEPTÉE': 'accepted',
                                    'EN_ATTENTE': 'en_attente',
                                    'A_REASSIGNER': 'en_attente',
                                    'REFUSÉE': 'refused',
                                    'TERMINÉE': 'completed',
                                    'EXPIRÉE': 'expired',
                                    'ANNULÉE': 'cancelled'
                                }[demande.statut] ?? demande.statut|lower|replace({'_': '_'}) %}
                                <span class="card__status status--{{ statusClass }}">{{ demande.statut|replace({'_': ' '}) }}</span>
                            </div>
                            
                            <p style="margin: 12px 0; color: #666; line-height: 1.5;">{{ demande.descriptionBesoin|length > 120 ? demande.descriptionBesoin|slice(0, 120) ~ '…' : demande.descriptionBesoin }}</p>
                            
                            <div class="card__info">
                                <div>
                                    <strong>Type de patient:</strong><br>{{ demande.typePatient|replace({'_': ' '}) }}
                                </div>
                                <div>
                                    <strong>Budget:</strong><br>{{ demande.budgetMax }} DT
                                </div>
                                <div>
                                    <strong>Début souhaitée:</strong><br>{{ demande.dateDebutSouhaitee ? demande.dateDebutSouhaitee|date('d/m/Y H:i') : 'N/A' }}
                                </div>
                                <div>
                                    <strong>Créée:</strong><br>{{ demande.dateCreation ? demande.dateCreation|date('d/m/Y H:i') : 'N/A' }}
                                </div>
                            </div>
                            
                            <div class="card__actions">
                                {% if demande.statut in ['EN_ATTENTE', 'A_REASSIGNER'] and not demande.aideChoisie %}
                                    <a href="{{ path('app_demande_select_aide', {id: demande.id}) }}" class="btn btn--select">👥 Sélectionner un aide</a>
                                {% endif %}
                                {% if demande.statut in ['EN_ATTENTE', 'A_REASSIGNER'] %}
                                    <a href="{{ path('app_demande_aide_edit', {id: demande.id}) }}" class="btn btn--edit">✏️ Modifier</a>
                                {% endif %}
                                <a href="{{ path('app_demande_aide_show', {id: demande.id}) }}" class="btn btn--info">👁️ Suivre</a>
                                {% if demande.statut not in ['TERMINÉE', 'EXPIRÉE', 'ANNULÉE'] %}
                                    <form method="POST" action="{{ path('app_demande_aide_delete', {id: demande.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette demande ?');">
                                        <button type="submit" class="btn btn--danger">❌ Annuler</button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </main>
</div>
{% endblock %}
