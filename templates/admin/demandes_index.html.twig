{% extends 'base.html.twig' %}

{% block title %}Demandes d'Aide - Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/medecin/dashboard.css') }}">
    <style>
        .admin-filter-grid {
            display: grid;
            grid-template-columns: 1fr 220px auto;
            gap: 12px;
            align-items: center;
        }

        .admin-filter-grid input,
        .admin-filter-grid select {
            width: 100%;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 14px;
            background: #fff;
        }

        .admin-filter-grid button {
            border-radius: 8px;
            padding: 10px 16px;
            font-weight: 600;
        }

        .admin-table-wrap {
            overflow-x: auto;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 920px;
        }

        .admin-table thead th {
            text-align: left;
            font-size: 13px;
            color: #666;
            padding: 12px;
            border-bottom: 2px solid #eee;
            background: #fafafa;
        }

        .admin-table tbody td {
            padding: 12px;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .admin-table tbody tr:hover {
            background: #fcfcfc;
        }

        .actions-inline {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .btn-mini {
            border: 1px solid transparent;
            color: #334155;
            border-radius: 6px;
            padding: 6px 9px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-mini:hover {
            filter: brightness(0.98);
            color: #334155;
        }

        .btn-mini--view { background: #bfdbfe; border-color: #93c5fd; }
        .btn-mini--edit { background: #fde68a; border-color: #fcd34d; }
        .btn-mini--delete { background: #fecaca; border-color: #fca5a5; }

        .status-chip {
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }

        .status-success { background: #bbf7d0; color: #14532d; }
        .status-warning { background: #fde68a; color: #78350f; }
        .status-danger { background: #fecaca; color: #7f1d1d; }
        .status-expired { background: #ddd6fe; color: #4c1d95; }

        @media (max-width: 900px) {
            .admin-filter-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="portal">
    {% include 'side_bar.html.twig' %}

    <main class="portal__main">
        <div class="portal__top">
            <div>
                <h1 class="portal__title">📋 Gestion des Demandes d'Aide</h1>
                <p class="portal__subtitle">Design aligné sur l'historique côté aide-soignant/patient</p>
            </div>
        </div>

        <div class="portal__content">
    {# Messages Flash #}
    {% if app.flashes %}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type === 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    {# Filter Form #}
            <div class="box" style="margin-bottom: 16px;">
                <form method="get" class="admin-filter-grid">
                    <input type="text" name="search" placeholder="🔍 Rechercher une demande..." value="{{ search }}">
                    <select name="statut">
                        <option value="">Tous les statuts</option>
                        <option value="EN_ATTENTE" {{ statut === 'EN_ATTENTE' ? 'selected' : '' }}>En attente</option>
                        <option value="ACCEPTÉE" {{ statut === 'ACCEPTÉE' ? 'selected' : '' }}>Acceptée</option>
                        <option value="A_REASSIGNER" {{ statut === 'A_REASSIGNER' ? 'selected' : '' }}>À réassigner</option>
                        <option value="EXPIRÉE" {{ statut === 'EXPIRÉE' ? 'selected' : '' }}>Expirée</option>
                        <option value="ANNULÉE" {{ statut === 'ANNULÉE' ? 'selected' : '' }}>Annulée</option>
                    </select>
                    <button type="submit" class="btn btn--primary">Filtrer</button>
                </form>
            </div>

    {# Demandes Table #}
            <div class="box">
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Patient</th>
                        <th>Statut</th>
                        <th>Date Début</th>
                        <th>Budget</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                        </thead>
                        <tbody>
                    {% if demandes|length > 0 %}
                        {% for demande in demandes %}
                            <tr>
                                <td>
                                    <strong>{{ demande.titreD and demande.titreD|length > 30 ? demande.titreD|slice(0, 30) ~ '…' : (demande.titreD ?? 'N/A') }}</strong>
                                </td>
                                <td>{{ demande.email }}</td>
                                <td>
                                    {% set statusClass = demande.statut == 'ACCEPTÉE' ? 'status-success' : (demande.statut == 'EN_ATTENTE' ? 'status-warning' : (demande.statut == 'EXPIRÉE' ? 'status-expired' : 'status-danger')) %}
                                    <span class="status-chip {{ statusClass }}">
                                        {{ demande.statut|replace({'_': ' '}) }}
                                    </span>
                                </td>
                                <td>{{ demande.dateDebutSouhaitee ? demande.dateDebutSouhaitee|date('d/m/Y') : '-' }}</td>
                                <td>{{ demande.budgetMax ? demande.budgetMax ~ ' DT' : '-' }}</td>
                                <td>
                                    <div class="actions-inline">
                                    <a href="{{ path('admin_demandes_show', {id: demande.id}) }}" class="btn-mini btn-mini--view" title="Voir">👁️</a>
                                    <a href="{{ path('admin_demandes_edit', {id: demande.id}) }}" class="btn-mini btn-mini--edit" title="Modifier">✏️</a>
                                    <form method="post" action="{{ path('admin_demandes_delete', {id: demande.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-demande-' ~ demande.id) }}">
                                        <button type="submit" class="btn-mini btn-mini--delete" title="Supprimer">🗑️</button>
                                    </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="6" style="text-align:center; color:#999; padding: 24px;">Aucune demande trouvée</td>
                        </tr>
                    {% endif %}
                </tbody>
                    </table>
                </div>
            </div>
        </div>

    </main>
</div>
{% endblock %}
